# Multi-stage Dockerfile for cfde-atlas.
#
# Target: a small image that runs the Next.js 16 production server with
# `next start` semantics, built once from the standalone output.
#
# Build context MUST be the repo root, so the Dockerfile can see
# package.json, package-lock.json, app/, public/, next.config.ts, etc.
#
#   docker build -f deploy/docker/Dockerfile -t monode/cfde-atlas:local .
#
# The image expects `output: 'standalone'` in next.config.ts (already set).

# --- deps -----------------------------------------------------------------
# Install npm dependencies in a layer cacheable by package-lock.json alone.
FROM node:22-alpine AS deps
WORKDIR /app
# libc6-compat is a precaution for native deps that occasionally link
# against glibc symbols (sharp, etc.); harmless if nothing needs it.
RUN apk add --no-cache libc6-compat
COPY package.json package-lock.json* ./
RUN npm ci --no-audit --no-fund

# --- builder --------------------------------------------------------------
# Compile the Next.js production bundle. Standalone output mode emits a
# minimal `.next/standalone/` directory containing only the files needed
# to serve the app — no full node_modules in the final image.
FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
# Telemetry is opt-out but explicit silence beats accidental opt-in.
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# --- runner ---------------------------------------------------------------
# Production image. No source tree, no devDependencies, no compiler — only
# the standalone server, public assets, and the prebuilt static chunks.
FROM node:22-alpine AS runner
WORKDIR /app

# OCI image labels. The `org.opencontainers.image.source` value is what
# auto-associates the GHCR package with this GitHub repository (so the
# package can inherit repo visibility, link to releases, etc.). The CI
# workflow under .github/workflows/publish-container.yml ALSO sets
# these via docker/metadata-action, which overrides at build time, but
# having them in the Dockerfile means local-built images carry the
# right metadata too.
LABEL org.opencontainers.image.source="https://github.com/seandavi/cfde-atlas"
LABEL org.opencontainers.image.description="Conversational interface for CFDE evaluation metrics"
LABEL org.opencontainers.image.licenses="MIT"
LABEL org.opencontainers.image.url="https://cfde-atlas.cancerdatasci.org"

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

# Run as a non-root user. The standalone server needs nothing beyond
# read access to its own files.
RUN addgroup --system --gid 1001 nodejs \
 && adduser  --system --uid 1001 nextjs

# `public/` is not bundled into standalone — copy it explicitly.
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

# The standalone output tree already contains the minimal node_modules
# and a server.js entrypoint. `.next/static/` is also separate and must
# be copied alongside.
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs
EXPOSE 3000

# server.js is generated by `next build` in standalone mode; it boots
# the same Next.js production server `next start` would, without the CLI.
CMD ["node", "server.js"]
