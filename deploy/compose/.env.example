# Copy to .env (gitignored — covered by the root .gitignore's .env*
# rule) and fill in. `docker compose up` auto-loads .env from the same
# directory as the compose file.

# Gemini API access via @ai-sdk/google. Required.
# https://ai.google.dev/gemini-api/docs/api-key
GOOGLE_GENERATIVE_AI_API_KEY=

# Postgres connection string. Required — the chat tools introspect and
# query the `analytics` schema directly. Format:
#   postgresql://<role>:<pw>@pg_main:5432/<db>
# The compose file already attaches this service to the
# `pg_ducklake_stack_default` network so `pg_main` resolves.
#
# On onclappc02, the dev password is in GSM (project: cdsci-infra):
#   gcloud secrets versions access latest \
#     --secret=cfde-atlas-dev-db-password-onclappc02 --project=cdsci-infra
DATABASE_URL=

# HMAC secret used by the app to sign per-session caller cookies. Required.
# Generate with:
#   openssl rand -base64 32
SESSION_SIGNING_SECRET=

# Public origin used by the share endpoint to mint /c/<code> URLs.
# Optional — defaults to the production hostname via the compose file.
PUBLIC_BASE_URL=https://cfde-atlas.cancerdatasci.org
