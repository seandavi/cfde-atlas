# Copy to .env.local and fill in. .env.local is gitignored.

# Gemini API access via @ai-sdk/google. Required.
# https://ai.google.dev/gemini-api/docs/api-key
GOOGLE_GENERATIVE_AI_API_KEY=

# Postgres connection string. Required — the chat tools introspect and query
# the `analytics` schema directly.
# Example: postgres://user:pass@host:5432/cfde_atlas
# On onclappc02 the dev password is in GSM (project: cdsci-infra):
#   gcloud secrets versions access latest \
#     --secret=cfde-atlas-dev-db-password-onclappc02 --project=cdsci-infra
DATABASE_URL=

# HMAC secret used to sign the per-session caller cookie. Required in
# production (>= 16 chars). In dev, falls back to a derivation of
# DATABASE_URL so local iteration does not require the secret.
SESSION_SIGNING_SECRET=

# Base URL used when minting share links (e.g. https://cfde-atlas.example.org).
# Optional — when unset, the share endpoint derives the origin from the
# incoming Host + X-Forwarded-Proto headers.
PUBLIC_BASE_URL=

# --- Gemini context caching (optional) ---
# When enabled, the chat route attaches a server-side cachedContent
# resource that holds the system prompt, full analytics-schema dump,
# and knowledge files under app/lib/knowledge. Cached input tokens
# bill at ~25% of the normal input rate and dropped tool round-trips
# are the bigger latency win.
# Set to "1" or "true" to enable. Default off.
GEMINI_CACHE_ENABLED=

# TTL applied to the server-side cache. Shorter = less idle storage
# cost, more cache-creates. Default 900 (15 min). Min 60s.
GEMINI_CACHE_TTL_SEC=
