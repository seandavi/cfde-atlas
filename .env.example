# Copy to .env.local and fill in. .env.local is gitignored.

# Gemini API access via @ai-sdk/google. Required.
# https://ai.google.dev/gemini-api/docs/api-key
GOOGLE_GENERATIVE_AI_API_KEY=

# Postgres connection string. Not yet required — the chat tools currently
# operate against mocked sample data. Will be required once ETL lands.
# Example: postgres://user:pass@host:5432/cfde_atlas
DATABASE_URL=
